# 서버의 /opt/app/.env 로 저장 (이 파일을 복사 후 실제 값 채우기)
# ⚠️ 운영 서버이므로 NODE_ENV=production 必
# ⚠️ 이 .env 는 git 에 올리지 말 것 (.gitignore 에 이미 포함)

NODE_ENV=production
PORT=3000

# ─ DB (로컬 .env 의 값을 그대로) ─
DATABASE_URL=mysql://...:...@gateway...tidbcloud.com:4000/...?ssl={"rejectUnauthorized":true}
JWT_SECRET=...

# ─ (마누스 OAuth — 실제 미사용, 비워둬도 동작) ─
VITE_APP_ID=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ─ 노션 / 구글시트 연동 쓰면 채우기 ─
NOTION_API_KEY=
NOTION_DATABASE_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_SHEET_ID=

# ─ 프론트 표시용 ─
VITE_APP_TITLE=꿈비 통합 비즈니스 대시보드
